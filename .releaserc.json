{
  "branches": [
    "main",
    { "name": "next", "prerelease": "rc" },
    { "name": "beta", "prerelease": "beta" }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "bash tool/bump_versions.sh ${nextRelease.version}",
        "publishCmd": "bash tool/publish_packages.sh"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "packages/norbix_core/pubspec.yaml",
          "packages/norbix_api/pubspec.yaml",
          "packages/norbix_hub/pubspec.yaml"
        ],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
